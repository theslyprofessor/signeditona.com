---
import type { PortfolioArtist } from '../lib/convex'
interface Props {
  artist: PortfolioArtist
}
const { artist } = Astro.props
const paragraphs = (artist.bio ?? '').split('\n\n').filter(Boolean)
---

<section
  id="about"
  class="border-t border-white/5 py-20 md:py-32 bg-gradient-to-b from-ink to-neutral-950"
>
  <div class="max-page grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
    <div class="lg:col-span-4">
      <p class="eyebrow text-ember mb-3">About</p>
      <h2 class="font-display italic text-5xl md:text-7xl leading-[0.95] mb-8">
        Stay <br /><span class="text-ember">grounded.</span>
      </h2>
      <p class="text-bone/70 max-w-sm leading-relaxed">
        Mexican-American muralist. Photo-realist with a surrealist tilt.
        Voice in the booth. Songs in the works. One of the official
        muralists of the San Diego Padres.
      </p>
    </div>
    <div class="lg:col-span-8 space-y-6 text-lg md:text-xl leading-relaxed text-bone/90">
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </div>
</section>
