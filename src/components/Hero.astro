---
import type { PortfolioArtist } from '../lib/convex'
interface Props {
  artist: PortfolioArtist
  totalWorks: number
}
const { artist, totalWorks } = Astro.props
const tagline = artist.tagline ?? 'Muralist. Voice. Storyteller.'
---

<header
  id="top"
  class="relative min-h-[90vh] flex flex-col justify-between pt-28 pb-12 px-6 md:px-12 lg:px-20 overflow-hidden"
>
  <div class="relative flex justify-between items-start eyebrow">
    <span class="text-coral">Murals · Voice · Song</span>
    <span>{artist.location ?? 'San Diego, California'}</span>
  </div>

  <div class="relative float-up max-w-[1400px]">
    <p class="eyebrow text-coral mb-5 md:mb-7">{tagline}</p>
    <h1
      class="font-display font-medium leading-[0.95] tracking-[-0.03em] text-[19vw] md:text-[14vw] lg:text-[11rem]"
    >
      Signe <span class="text-coral">Ditona</span>
    </h1>
    <p
      class="mt-7 md:mt-9 max-w-2xl text-lg md:text-2xl leading-relaxed text-ivory/75 font-sans"
    >
      Muralist and singer based in San Diego. Co-founder of Ground Floor Murals.
    </p>

    <div class="mt-9 flex flex-wrap gap-3 md:gap-4">
      <a
        href="#work"
        class="inline-flex items-center gap-2 rounded-full bg-coral px-7 py-3.5 font-mono text-xs uppercase tracking-[0.18em] text-ink hover:bg-coraldark transition-colors"
        >See the murals <span aria-hidden>↓</span></a
      >
      <a
        href="#contact"
        class="inline-flex items-center gap-2 rounded-full border border-ivory/25 px-7 py-3.5 font-mono text-xs uppercase tracking-[0.18em] text-ivory hover:border-coral hover:text-coral transition-colors"
        >Commission a wall</a
      >
    </div>
  </div>

  <div class="relative flex justify-between items-end eyebrow mt-12">
    <span>
      <span class="text-coral">{String(totalWorks).padStart(3, '0')}</span> works on view
    </span>
    <a href="#work" class="hover:text-coral transition-colors">scroll ↓</a>
  </div>
</header>
