---
import type { PortfolioArtist } from '../lib/convex'
interface Props {
  artist: PortfolioArtist
  totalWorks: number
}
const { artist, totalWorks } = Astro.props
const tagline = artist.tagline ?? 'Muralist. Voice. Storyteller.'
---

<header
  id="top"
  class="relative min-h-[92vh] flex flex-col justify-between pt-24 pb-10 px-6 md:px-12 lg:px-20 overflow-hidden"
>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(80% 50% at 20% 10%, rgba(232,73,58,0.18), transparent 60%), radial-gradient(60% 40% at 90% 90%, rgba(232,73,58,0.10), transparent 70%);"
  >
  </div>

  <div class="relative flex justify-between items-start eyebrow">
    <span class="text-ember">Signe Ditona</span>
    <span>{artist.location ?? 'San Diego, California'}</span>
  </div>

  <div class="relative float-up max-w-[1500px]">
    <p class="eyebrow text-ember mb-6 md:mb-10">{tagline}</p>
    <h1
      class="font-display italic leading-[0.85] tracking-tight text-[20vw] md:text-[14vw] lg:text-[12vw]"
    >
      Signe<br />
      <span class="text-ember">Ditona</span>
    </h1>
    <p
      class="mt-6 md:mt-10 max-w-2xl text-lg md:text-2xl leading-relaxed text-bone/85"
    >
      Muralist, voice artist, and singer based in San Diego. Co-founder of
      <em class="not-italic underline decoration-ember/60 underline-offset-4"
        >Ground Floor Murals</em
      >. Photo-realism, surrealism, and the kind of public work that asks
      neighborhoods to love themselves out loud.
    </p>

    <div class="mt-10 flex flex-wrap gap-3 md:gap-4">
      <a
        href="#work"
        class="inline-flex items-center gap-2 bg-ember text-ink px-5 py-3 text-xs tracking-[0.3em] uppercase hover:bg-bone transition-colors"
        >View Work <span aria-hidden>↓</span></a
      >
      <a
        href="#contact"
        class="inline-flex items-center gap-2 border border-bone/30 text-bone px-5 py-3 text-xs tracking-[0.3em] uppercase hover:border-bone hover:bg-bone hover:text-ink transition-colors"
        >Commission</a
      >
    </div>
  </div>

  <div class="relative flex justify-between items-end eyebrow mt-12">
    <span>{String(totalWorks).padStart(3, '0')} works on view</span>
    <a href="#work" class="hover:text-ember transition-colors">scroll ↓</a>
  </div>
</header>
