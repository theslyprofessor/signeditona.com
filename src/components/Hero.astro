---
import type { PortfolioArtist } from '../lib/convex'
interface Props {
  artist: PortfolioArtist
  totalWorks: number
}
const { artist, totalWorks } = Astro.props
const tagline = artist.tagline ?? 'Muralist. Voice. Storyteller.'
---

<header
  id="top"
  class="relative min-h-[94vh] flex flex-col justify-between pt-24 pb-10 px-6 md:px-12 lg:px-20 overflow-hidden"
>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(70% 50% at 12% 8%, rgba(224,33,138,0.22), transparent 60%), radial-gradient(55% 45% at 95% 25%, rgba(245,166,35,0.16), transparent 65%), radial-gradient(60% 50% at 80% 100%, rgba(31,168,123,0.16), transparent 70%);"
  >
  </div>

  <!-- Oversized ghost word behind the name -->
  <span
    aria-hidden
    class="pointer-events-none absolute -right-4 top-1/3 select-none font-display uppercase stroke-bone text-[40vw] leading-none rotate-[-4deg]"
  >SD</span>

  <div class="relative flex justify-between items-start eyebrow">
    <span class="text-rosa">Ground Floor Murals</span>
    <span class="text-bone/60">{artist.location ?? 'San Diego, California'}</span>
  </div>

  <div class="relative float-up max-w-[1500px]">
    <p class="eyebrow text-marigold mb-5 md:mb-8">{tagline}</p>
    <h1
      class="font-display uppercase leading-[0.82] tracking-[0.005em] text-[23vw] md:text-[15vw] lg:text-[13vw]"
    >
      <span class="text-bone">Signe</span><br />
      <span class="text-ember">Ditona</span>
    </h1>
    <p
      class="mt-6 md:mt-10 max-w-2xl text-lg md:text-2xl leading-relaxed text-bone/85 font-sans"
    >
      Muralist, voice artist, and singer based in San Diego. Co-founder of
      <a
        href="https://www.groundfloormurals.com"
        class="font-semibold text-bone underline decoration-rosa decoration-2 underline-offset-4 hover:text-rosa transition-colors"
        >Ground Floor Murals</a
      >. Photo-realism, surrealism, and public work that asks neighborhoods
      to love themselves out loud.
    </p>

    <div class="mt-9 flex flex-wrap gap-3 md:gap-4">
      <a
        href="#work"
        class="inline-flex items-center gap-2 bg-rosa text-bone px-6 py-3.5 eyebrow hover:bg-ember transition-colors"
        >See the murals <span aria-hidden>↓</span></a
      >
      <a
        href="#contact"
        class="inline-flex items-center gap-2 border-2 border-bone/30 text-bone px-6 py-3.5 eyebrow hover:border-marigold hover:text-marigold transition-colors"
        >Commission a wall</a
      >
    </div>
  </div>

  <div class="relative flex justify-between items-end eyebrow mt-12">
    <span class="text-bone/60">
      <span class="text-jade">{String(totalWorks).padStart(3, '0')}</span> works on view
    </span>
    <a href="#work" class="text-bone/60 hover:text-marigold transition-colors">scroll ↓</a>
  </div>
</header>
