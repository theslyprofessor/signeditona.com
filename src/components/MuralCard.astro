---
/**
 * Clickable mural tile. Opens the lightbox dialog (#lightbox) populated
 * from the work's data-* attributes (hydrated by Lightbox.astro).
 */
import type { PortfolioWork } from '../lib/convex'
import MuralCover from './MuralCover.astro'

interface Props {
  work: PortfolioWork
  size?: 'sm' | 'md' | 'lg'
}
const { work, size = 'md' } = Astro.props
const aspect =
  size === 'lg' ? 'aspect-[4/5]' : size === 'sm' ? 'aspect-square' : 'aspect-[4/5]'

const tags = (work.tags ?? []).join(',')
const images = (work.imageUrls ?? []).join('|')
---

<button
  type="button"
  class={`group relative ${aspect} w-full overflow-hidden rounded-2xl bg-oatdeep cursor-zoom-in text-left ring-1 ring-espresso/10`}
  data-mural
  data-mural-id={work._id}
  data-mural-title={work.title}
  data-mural-subtitle={work.subtitle ?? ''}
  data-mural-description={work.description ?? ''}
  data-mural-location={work.location ?? ''}
  data-mural-year={work.year ?? ''}
  data-mural-images={images}
  data-mural-source={work.sourceUrl ?? ''}
  data-mural-tags={tags}
  data-mural-featured={work.isFeatured ? '1' : '0'}
  aria-label={`Open ${work.title}`}
>
  <MuralCover work={work} large={size === 'lg'} />
  <div
    class="absolute inset-x-0 bottom-0 p-4 md:p-5 bg-gradient-to-t from-espresso/90 via-espresso/35 to-transparent translate-y-2 md:translate-y-4 md:opacity-0 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300"
  >
    <h3 class="font-display font-medium text-2xl md:text-3xl leading-tight text-oat">
      {work.title}
    </h3>
    {work.location && (
      <p class="mt-1.5 text-[10px] font-semibold uppercase tracking-[0.24em] text-oat/75">
        {work.location}
      </p>
    )}
  </div>
  <span
    class="absolute top-3 right-3 w-8 h-8 rounded-full bg-oat/85 backdrop-blur-sm flex items-center justify-center text-espresso text-sm group-hover:bg-terracotta group-hover:text-oat transition-colors"
    aria-hidden
  >
    ↗
  </span>
</button>
