---
interface Outlet {
  name: string
  headline: string
  url: string
  date: string
}

const outlets: Outlet[] = [
  {
    name: 'KPBS',
    headline: 'Muralist finds inspiration in Mexican heritage',
    url: 'https://www.kpbs.org/news/local/2022/09/15/muralist-finds-inspiration-in-mexican-heritage',
    date: 'Sept 2022',
  },
  {
    name: '10News',
    headline:
      'San Diego artists honor Mexican singer Vicente Fernández with mural',
    url: 'https://www.10news.com/news/local-news/san-diego-artists-honor-mexican-singer-vicente-fernandez-with-mural',
    date: '2022',
  },
  {
    name: 'CBS 8',
    headline:
      'Ground Floor Murals making San Diego sports larger than life',
    url: 'https://www.cbs8.com/article/sports/mlb/padres/ground-floor-murals-making-san-diego-sports-larger-than-life-joe-musgrove-fernando-tatis-padres-tony-gwynn-artwork/509-88e83741-f79d-4781-8e91-6e7acb1c6864',
    date: '2022',
  },
  {
    name: 'The Long Hairs',
    headline: 'Painting the town with hands that are brown',
    url: 'https://blog.thelonghairs.us/ground-floor-murals/',
    date: '2022',
  },
]
---

<section id="press" class="border-t border-white/5 py-20 md:py-32">
  <div class="max-page">
    <div class="flex items-baseline gap-6 mb-12">
      <p class="eyebrow text-jade">In the press</p>
      <h2 class="font-display text-5xl md:text-7xl">Press</h2>
    </div>

    <ul class="divide-y divide-white/10 border-y border-white/10">
      {outlets.map((o) => (
        <li>
          <a
            href={o.url}
            target="_blank"
            rel="noreferrer"
            class="group flex flex-col md:flex-row md:items-center md:justify-between gap-2 py-6 md:py-8 hover:bg-white/[0.02] -mx-4 px-4 transition-colors"
          >
            <div class="flex items-baseline gap-4 md:gap-6">
              <span class="eyebrow text-jade w-20 shrink-0">{o.name}</span>
              <span class="font-sans font-bold text-lg md:text-2xl leading-snug group-hover:text-jade transition-colors">
                {o.headline}
              </span>
            </div>
            <div class="flex items-center gap-4 eyebrow text-bone/50 shrink-0">
              <span>{o.date}</span>
              <span aria-hidden>↗</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
