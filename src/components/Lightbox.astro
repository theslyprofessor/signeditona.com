---
/**
 * Singleton lightbox dialog. Lives once at the bottom of every page that
 * contains MuralCards. Click on a card → script reads data-* attributes
 * off the trigger and hydrates the dialog. Native <dialog> handles ESC,
 * focus trap, and click-out behavior.
 */
---

<dialog
  id="lightbox"
  class="bg-oat text-espresso backdrop:bg-espresso/55 backdrop:backdrop-blur-md p-0 m-0 max-w-none max-h-none w-screen h-screen"
>
  <div class="w-full h-full flex flex-col" data-lightbox-root>
    <header class="flex items-center justify-between px-6 md:px-12 py-4 border-b border-espresso/10">
      <p class="eyebrow text-terracotta" data-lb-medium>Mural</p>
      <button
        type="button"
        class="text-espresso/60 hover:text-terracotta transition-colors text-2xl leading-none w-10 h-10 flex items-center justify-center"
        data-lb-close
        aria-label="Close"
      >×</button>
    </header>

    <div class="flex-1 grid grid-cols-1 lg:grid-cols-5 overflow-auto">
      <div class="lg:col-span-3 bg-oatdeep flex items-center justify-center min-h-[40vh] lg:min-h-[60vh] relative">
        <img
          data-lb-image
          alt=""
          class="hidden max-w-full max-h-full object-contain"
        />
        <div
          data-lb-placeholder
          class="absolute inset-0 flex items-center justify-center"
          style="background: radial-gradient(circle at 30% 20%, rgba(229,96,77,0.16), transparent 60%), radial-gradient(circle at 80% 90%, rgba(217,162,75,0.16), transparent 60%), #E9E0D2;"
        >
          <span
            class="font-display italic text-[24vw] lg:text-[14vw] text-terracotta/30"
            data-lb-initial
          >S</span>
        </div>
        <div class="absolute bottom-4 left-4 right-4 flex gap-2 flex-wrap" data-lb-thumbs></div>
      </div>

      <aside class="lg:col-span-2 p-6 md:p-10 overflow-auto">
        <p class="eyebrow text-terracotta mb-3" data-lb-eyebrow>Featured · Mural</p>
        <h2 class="font-display text-4xl md:text-6xl font-medium leading-[0.95] mb-4" data-lb-title>Title</h2>
        <p class="text-espresso/70 text-lg mb-6" data-lb-subtitle></p>
        <p class="text-espresso/85 leading-relaxed text-base md:text-lg mb-8 font-sans" data-lb-description></p>
        <dl class="grid grid-cols-2 gap-y-4 gap-x-8 text-sm">
          <div data-lb-field-location>
            <dt class="eyebrow mb-1">Where</dt>
            <dd class="text-espresso font-sans" data-lb-location></dd>
          </div>
          <div data-lb-field-year>
            <dt class="eyebrow mb-1">When</dt>
            <dd class="text-espresso font-sans" data-lb-year></dd>
          </div>
          <div class="col-span-2" data-lb-field-tags>
            <dt class="eyebrow mb-1">Notes</dt>
            <dd class="text-espresso font-sans" data-lb-tags></dd>
          </div>
        </dl>
        <a
          data-lb-source
          target="_blank"
          rel="noreferrer"
          class="hidden mt-8 inline-flex items-center gap-2 rounded-full bg-terracotta text-oat px-6 py-3 text-xs font-semibold uppercase tracking-[0.26em] hover:bg-clay transition-colors"
        >Press →</a>
      </aside>
    </div>

    <footer class="flex items-center justify-between px-6 md:px-12 py-4 border-t border-espresso/10 eyebrow">
      <button data-lb-prev class="hover:text-terracotta transition-colors">← Prev</button>
      <span data-lb-counter>1 / 1</span>
      <button data-lb-next class="hover:text-terracotta transition-colors">Next →</button>
    </footer>
  </div>
</dialog>

<script>
  type Mural = {
    id: string
    title: string
    subtitle: string
    description: string
    location: string
    year: string
    images: string[]
    sourceUrl: string
    tags: string[]
    featured: boolean
  }

  const dialog = document.querySelector('#lightbox') as HTMLDialogElement | null
  if (dialog) {
    const triggers = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-mural]'),
    )
    const murals: Mural[] = triggers.map((t) => ({
      id: t.dataset.muralId ?? '',
      title: t.dataset.muralTitle ?? '',
      subtitle: t.dataset.muralSubtitle ?? '',
      description: t.dataset.muralDescription ?? '',
      location: t.dataset.muralLocation ?? '',
      year: t.dataset.muralYear ?? '',
      images: (t.dataset.muralImages ?? '').split('|').filter(Boolean),
      sourceUrl: t.dataset.muralSource ?? '',
      tags: (t.dataset.muralTags ?? '').split(',').filter(Boolean),
      featured: t.dataset.muralFeatured === '1',
    }))

    let index = 0

    const $ = (sel: string) => dialog.querySelector(sel) as HTMLElement
    const eyebrow = $('[data-lb-eyebrow]')
    const title = $('[data-lb-title]')
    const subtitle = $('[data-lb-subtitle]')
    const description = $('[data-lb-description]')
    const locationEl = $('[data-lb-location]')
    const yearEl = $('[data-lb-year]')
    const tagsEl = $('[data-lb-tags]')
    const fieldLocation = $('[data-lb-field-location]')
    const fieldYear = $('[data-lb-field-year]')
    const fieldTags = $('[data-lb-field-tags]')
    const source = $('[data-lb-source]') as HTMLAnchorElement
    const image = $('[data-lb-image]') as HTMLImageElement
    const placeholder = $('[data-lb-placeholder]')
    const placeholderInitial = $('[data-lb-initial]')
    const counter = $('[data-lb-counter]')

    function show(i: number) {
      if (!murals.length) return
      const wrapped = (i + murals.length) % murals.length
      index = wrapped
      const m = murals[wrapped]
      eyebrow.textContent = m.featured ? 'Featured · Mural' : 'Mural'
      title.textContent = m.title
      subtitle.textContent = m.subtitle
      subtitle.classList.toggle('hidden', !m.subtitle)
      description.textContent = m.description
      description.classList.toggle('hidden', !m.description)
      locationEl.textContent = m.location
      fieldLocation.classList.toggle('hidden', !m.location)
      yearEl.textContent = m.year
      fieldYear.classList.toggle('hidden', !m.year)
      tagsEl.textContent = m.tags.join(', ')
      fieldTags.classList.toggle('hidden', m.tags.length === 0)
      if (m.images.length > 0) {
        image.src = m.images[0]
        image.alt = m.title
        image.classList.remove('hidden')
        placeholder.classList.add('hidden')
      } else {
        image.classList.add('hidden')
        placeholder.classList.remove('hidden')
        placeholderInitial.textContent = m.title.charAt(0).toUpperCase()
      }
      if (m.sourceUrl) {
        source.href = m.sourceUrl
        source.classList.remove('hidden')
      } else {
        source.classList.add('hidden')
      }
      counter.textContent = `${wrapped + 1} / ${murals.length}`
    }

    triggers.forEach((t, i) => {
      t.addEventListener('click', () => {
        show(i)
        dialog.showModal()
        document.body.style.overflow = 'hidden'
      })
    })

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) {
        dialog.close()
      }
    })
    dialog.addEventListener('close', () => {
      document.body.style.overflow = ''
    })
    $('[data-lb-close]').addEventListener('click', () => dialog.close())
    $('[data-lb-prev]').addEventListener('click', () => show(index - 1))
    $('[data-lb-next]').addEventListener('click', () => show(index + 1))

    document.addEventListener('keydown', (e) => {
      if (!dialog.open) return
      if (e.key === 'ArrowLeft') show(index - 1)
      if (e.key === 'ArrowRight') show(index + 1)
    })
  }
</script>
