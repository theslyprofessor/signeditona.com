---
/**
 * Tile-cover: real image when present, typographic monogram tile when
 * not. Keeps the gallery visually populated even before Signe uploads
 * proper image URLs into the CMS.
 */
import type { PortfolioWork } from '../lib/convex'
interface Props {
  work: PortfolioWork
  large?: boolean
}
const { work, large = false } = Astro.props
const cover = work.imageUrls?.[0]
const initial = work.title.charAt(0).toUpperCase()
---

{cover ? (
  <img
    src={cover}
    alt={work.title}
    loading="lazy"
    class="w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-105"
  />
) : (
  <div
    class="w-full h-full flex items-center justify-center"
    style="background: radial-gradient(circle at 30% 20%, rgba(232,73,58,0.18), transparent 60%), #0a0a0a;"
  >
    <span
      class={`font-display italic ${large ? 'text-[18vw] md:text-[10vw]' : 'text-[18vw] md:text-[8vw]'} text-ember/30`}
    >
      {initial}
    </span>
  </div>
)}
