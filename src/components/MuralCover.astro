---
/**
 * Tile-cover: real image when present, simple monogram tile when not.
 */
import type { PortfolioWork } from '../lib/convex'
interface Props {
  work: PortfolioWork
  large?: boolean
}
const { work, large = false } = Astro.props
const cover = work.imageUrls?.[0]
const initial = work.title.charAt(0).toUpperCase()
---

{cover ? (
  <img
    src={cover}
    alt={work.title}
    loading="lazy"
    class="w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-105"
  />
) : (
  <div
    class="w-full h-full flex items-center justify-center bg-coal"
  >
    <span
      class={`font-display ${large ? 'text-[18vw] md:text-[10vw]' : 'text-[18vw] md:text-[8vw]'} text-coral/30`}
    >
      {initial}
    </span>
  </div>
)}
