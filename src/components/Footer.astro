---
import type { PortfolioArtist } from '../lib/convex'
interface Props {
  artist: PortfolioArtist
}
const { artist } = Astro.props
const links = artist.links ?? []
const year = new Date().getFullYear()
---

<footer class="border-t border-ivory/10 py-10 md:py-14">
  <div
    class="max-page flex flex-col md:flex-row md:items-center md:justify-between gap-6 text-xs"
  >
    <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-6">
      <span class="font-display text-xl font-semibold tracking-[-0.02em]">
        Signe <span class="text-coral">Ditona</span>
      </span>
      <span class="text-ivory/50 font-sans">
        © {year}. All work shown is the artist's. All wrongs reserved.
      </span>
    </div>
    <ul class="flex flex-wrap gap-x-5 gap-y-2 text-ivory/60 font-sans">
      {links.map((l) => (
        <li>
          <a href={l.url} target="_blank" rel="noreferrer" class="font-semibold hover:text-coral">
            {l.label.replace(/ on Instagram$/, '')}
          </a>
        </li>
      ))}
    </ul>
  </div>
</footer>
