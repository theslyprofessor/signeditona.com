---
/**
 * Public holding page for the apex domain while the full site is in
 * progress. On-brand: black, Space Grotesk, single coral accent.
 */
---

<section
  class="min-h-screen flex flex-col justify-between px-6 md:px-12 lg:px-20 py-10 md:py-14"
>
  <div class="flex justify-between items-start eyebrow">
    <span class="text-coral">Signe Ditona</span>
    <span>San Diego, California</span>
  </div>

  <div class="flex-1 flex flex-col justify-center max-w-[1400px]">
    <p class="eyebrow text-coral mb-6">Muralist · Voice · Singer</p>
    <h1
      class="font-display font-medium leading-[0.95] tracking-[-0.03em] text-[19vw] md:text-[14vw] lg:text-[11rem]"
    >
      Signe <span class="text-coral">Ditona</span>
    </h1>
    <p
      class="mt-8 md:mt-10 font-mono text-sm md:text-base uppercase tracking-[0.22em] text-ivory/70"
    >
      New site coming soon.
    </p>
  </div>

  <div class="flex flex-wrap items-center gap-x-8 gap-y-3 eyebrow">
    <a
      href="https://www.instagram.com/signeditona"
      target="_blank"
      rel="noreferrer"
      class="hover:text-coral transition-colors"
      >@signeditona ↗</a
    >
    <a href="mailto:info@signeditona.com" class="hover:text-coral transition-colors"
      >info@signeditona.com</a
    >
  </div>
</section>
