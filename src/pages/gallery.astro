---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
import MuralCard from '../components/MuralCard.astro'
import Lightbox from '../components/Lightbox.astro'
import Footer from '../components/Footer.astro'
import { fetchArtist, fetchWorks } from '../lib/convex'

// Public apex shows the holding page; gallery only on staging/localhost.
const host = Astro.request.headers.get('host') ?? ''
if (host.endsWith('signeditona.com')) {
  return Astro.redirect('/')
}

const [artist, works] = await Promise.all([fetchArtist(), fetchWorks()])
const murals = works.filter((w) => w.medium === 'mural').sort((a, b) => {
  const ao = a.sortOrder ?? 0
  const bo = b.sortOrder ?? 0
  return ao - bo
})

const tagSet = new Set<string>()
murals.forEach((m) => (m.tags ?? []).forEach((t) => tagSet.add(t)))
const tags = Array.from(tagSet).sort()

const safeArtist =
  artist ?? {
    _id: 'fallback',
    slug: 'signe-ditona',
    displayName: 'Signe Ditona',
    isPublic: true,
    links: [],
  }
---

<BaseLayout
  title="Gallery · Signe Ditona"
  description="Every mural in Signe Ditona's archive. Click any tile for location, year, and press."
>
  <Nav />
  <main class="pt-20 md:pt-24">
    <section class="max-page pb-12 md:pb-16">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between mb-10 md:mb-16">
        <div>
          <p class="eyebrow text-coral mb-3">The archive</p>
          <h1 class="font-display text-6xl md:text-8xl lg:text-9xl font-medium leading-[0.95]">
            Every <span class="text-coral">wall</span>.
          </h1>
          <p class="mt-4 max-w-xl text-ivory/70 leading-relaxed font-sans">
            Tap any tile to expand. Use arrow keys or the prev / next buttons
            to walk the wall.
          </p>
        </div>
        <a
          href="/"
          class="eyebrow hover:text-coral transition-colors self-start"
        >← Back home</a>
      </div>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10" data-tag-filters>
          <button
            type="button"
            class="eyebrow rounded-full border border-ivory/40 bg-coal px-4 py-2 text-ivory hover:border-coral hover:text-coral transition-colors is-active"
            data-tag="all"
          >All · {murals.length}</button>
          {tags.map((t) => (
            <button
              type="button"
              class="eyebrow rounded-full border border-ivory/15 px-4 py-2 text-ivory/60 hover:border-coral hover:text-coral transition-colors"
              data-tag={t}
            >{t}</button>
          ))}
        </div>
      )}

      <ul
        class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-2 md:gap-3"
        data-gallery-grid
      >
        {murals.map((m) => (
          <li data-tile data-tile-tags={(m.tags ?? []).join(',')}>
            <MuralCard work={m} size="sm" />
          </li>
        ))}
      </ul>
    </section>
  </main>
  <Footer artist={safeArtist} />
  <Lightbox />
</BaseLayout>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('[data-tag-filters] button')
  const tiles = document.querySelectorAll<HTMLElement>('[data-tile]')
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? 'all'
      filters.forEach((b) => {
        const active = b === btn
        b.classList.toggle('is-active', active)
        b.classList.toggle('border-ivory/40', active)
        b.classList.toggle('bg-coal', active)
        b.classList.toggle('text-ivory', active)
        b.classList.toggle('border-ivory/15', !active)
        b.classList.toggle('text-ivory/60', !active)
      })
      tiles.forEach((tile) => {
        const tags = (tile.dataset.tileTags ?? '').split(',').filter(Boolean)
        const show = tag === 'all' || tags.includes(tag)
        tile.classList.toggle('hidden', !show)
      })
    })
  })
</script>
